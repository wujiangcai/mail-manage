MAIL_CODE_HOST=0.0.0.0
MAIL_CODE_PORT=17373

# Required for admin panel login.
MAIL_CODE_ADMIN_PASSWORD=change-this-admin-password

# Required for signing browser sessions. Use a long random value.
MAIL_CODE_SESSION_SECRET=change-this-long-random-session-secret

# Required for public deployments. Multiple keys can be separated by commas.
# These keys protect direct server-to-server /api/code and /api/messages calls.
MAIL_CODE_API_KEYS=change-this-long-random-key

# Optional CORS whitelist. Use your HTTPS domain in production.
MAIL_CODE_ALLOWED_ORIGINS=https://mail-code.example.com

# SQLite database path inside the container.
MAIL_CODE_DB_PATH=/app/data/mail-code-helper.sqlite3
